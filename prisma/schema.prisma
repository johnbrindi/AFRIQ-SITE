generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                 Int           @id @default(autoincrement())
  firstName          String        @map("first_name")
  lastName           String        @map("last_name")
  email              String        @unique
  phone              String
  password           String
  academicBackground String        @map("academic_background")
  applications       Application[]

  @@map("users")
}

model University {
  id       Int      @id
  name     String   @db.VarChar(255)
  short    String?  @db.VarChar(255)
  loc      String?  @db.VarChar(255)
  city     String?  @db.VarChar(255)
  reg      String?  @db.VarChar(255)
  tag      String?  @db.VarChar(255)
  est      String?  @db.VarChar(10)
  img      String?  @db.VarChar(255)
  logo     String?  @db.VarChar(255)
  about    String?
  missions Json?    @db.Json
  facts    Json?    @db.Json
  schools  School[]

  @@map("universities")
}

model School {
  id                 Int           @id @default(autoincrement())
  universityId       Int           @map("university_id")
  n                  String        @db.VarChar(255)
  acr                String?       @db.VarChar(255)
  t                  String?       @db.VarChar(255)
  i                  String?       @db.VarChar(16)
  departments        Json?         @db.Json
  formFields         Json?         @map("formfields") @db.Json
  schoolRequirements Json?         @map("schoolrequirements") @db.Json
  applications       Application[]
  university         University    @relation(fields: [universityId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("schools")
}

model Application {
  id                  Int       @id @default(autoincrement())
  userId              Int       @map("user_id")
  schoolId            Int       @map("school_id")
  personalInfo        Json?     @map("personal_info") @db.Json
  requirementsChecked Json?     @map("requirements_checked") @db.Json
  totalFee            Decimal?  @default(0) @map("total_fee") @db.Decimal(10, 2)
  createdAt           DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updated_at          DateTime? @default(now()) @db.Timestamptz(6)
  school              School    @relation(fields: [schoolId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("applications")
}
