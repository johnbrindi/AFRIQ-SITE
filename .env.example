# AFRIQ-SITE Environment Variables for Production
# Provide the actual values before running docker-compose up -d

# Database Connection URLs (e.g., Neon Postgres)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"
DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"

# NextAuth Configuration
# Generate a new secret using: openssl rand -base64 32
NEXTAUTH_SECRET="generate-a-new-secret-here"
# The public-facing URL of your site (e.g., https://afriq-site.com)
NEXTAUTH_URL="http://localhost:3000"

# Docker image username
DOCKER_USERNAME="your-dockerhub-username"
